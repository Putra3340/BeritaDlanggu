@model BeritaDlanggu.Models.ViewModels.SearchViewModel
<section class="container mt-4 mb-5">
    <!-- Search Bar -->
    <div class="card border-0 shadow-sm rounded-custom p-4 mb-4 fade-in">
        <form id="searchForm" class="d-flex gap-3" action="/Search">
            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute" style="left:16px;top:50%;transform:translateY(-50%);color:var(--gray-400)"></i>
                <input type="text" class="form-control" id="searchInput" placeholder="Cari berita, artikel, pengumuman..." style="padding-left:44px" value="@Model.Query" name="query">
            </div>
            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search me-1"></i> Cari</button>
        </form>
    </div>

    @if(Model.Query != null && Model.Query != "")
    {
    <!-- Results Header -->
    <div class="mb-4" id="searchResultsHeader" style="display: block;">
        <h5>Hasil pencarian: <span class="text-primary-custom" id="searchQuery">"@Model.Query"</span></h5>
        <p class="text-muted" id="searchCount">Ditemukan @Model.Articles.Count() berita</p>
    </div>
    }

    <!-- Category Filter -->
    <div class="category-chips mb-4" id="categoryFilter">
        @if(Model.CatId == null)
        {
            <a href="/Search?query=@Model.Query" class="category-chip active" data-cat="">Semua</a>
        }
        else
        {
            <a href="/Search?query=@Model.Query" class="category-chip" data-cat="">Semua</a>
        }
        @foreach(var cat in Model.Categories)
        {
            if(Model.CatId != null && Model.CatId == cat.Id.ToString())
            {
                <a href="/Search?query=@Model.Query&catid=@cat.Id" class="category-chip active" data-cat="@cat.Id">@cat.Name</a>
            }
            else
            {
                <a href="/Search?query=@Model.Query&catid=@cat.Id" class="category-chip" data-cat="@cat.Id">@cat.Name</a>
            }
        }
    </div>

    <!-- Results Grid -->
    <div class="row" id="searchGrid">
        @foreach (var result in Model.Articles)
        {
            <div class="col-md-6 col-lg-4 mb-4 fade-in">
                <div class="news-card">
                    <div class="card-img-wrapper">
                        <img src="@result.ThumbnailUrl" alt="@result.Title" loading="lazy">
                        <span class="category-badge">@result.Cat.Name</span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title"><a href="/Article/@result.Slug">@result.Title</a></h5>
                        <p class="card-excerpt">@result.Excerpt...</p>
                        <div class="card-meta d-flex flex-column align-items-start text-start">
                            <span>
                                <i class="bi bi-person me-1"></i>@result.Author.FullName
                            </span>

                            <div class="d-flex gap-3">
                                <span>
                                    <i class="bi bi-clock me-1"></i>@(result.PublishedAt == null ? result.UpdatedAt.ToString("dd MMMM yyyy") : result.PublishedAt?.ToString("dd MMMM yyyy"))
                                </span>
                                <span>
                                    <i class="bi bi-eye me-1"></i>@result.Views
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>