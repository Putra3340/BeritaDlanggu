@using BeritaDlanggu.Models.ViewModels
@{
    string PrimaryColor = ViewData[ServerSettingsKey.ThemeColor] as string;
    string AccentColor = ViewData[ServerSettingsKey.ThemeAccentColor] as string;
    string Adjust(string hex, int percent)
    {
        hex = hex.Replace("#", "");
        int r = Convert.ToInt32(hex.Substring(0, 2), 16);
        int g = Convert.ToInt32(hex.Substring(2, 2), 16);
        int b = Convert.ToInt32(hex.Substring(4, 2), 16);

        int AdjustChannel(int c)
        {
            return Math.Clamp(c + (int)(percent / 100.0 * 255), 0, 255);
        }

        r = AdjustChannel(r);
        g = AdjustChannel(g);
        b = AdjustChannel(b);

        return $"#{r:X2}{g:X2}{b:X2}";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO META -->
    <title>@ViewData["MetaTitle"]</title>
    <meta name="description" content="@ViewData["MetaDesc"]">
    <meta name="keywords" content="@ViewData["MetaKeyword"]">
    <meta name="author" content="@ViewData["MetaAuthor"]">
    <meta name="robots" content="@ViewData["MetaRobot"]">
    <!-- Open Graph (Facebook, Discord, etc.) -->
    <meta property="og:title" content="@ViewData["MetaTitle"]">
    <meta property="og:description" content="@ViewData["MetaDesc"]">
    <meta property="og:image" content="@ViewData["MetaImage"]">
    <meta property="og:url" content="@ViewData["MetaUrl"]">
    <meta property="og:type" content="@ViewData["MetaType"]">
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@ViewData["MetaTitle"]">
    <meta name="twitter:description" content="@ViewData["MetaDesc"]">
    <meta name="twitter:image" content="@ViewData["MetaImage"]">

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body>
    <div id="navbar-container" data-active="">
        <nav class="navbar navbar-expand-lg main-navbar">
            <div class="container">
                @{
                    var tagline = ViewData[ServerSettingsKey.TagLine]?.ToString();
                    var hasTagline = !string.IsNullOrWhiteSpace(tagline);
                }

                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <img src="~/icon-dlanggu.png"
                         class="brand-logo" />

                    <div class="brand-text @(hasTagline ? "with-tagline" : "no-tagline")">
                        <div class="brand-name">@ViewData[ServerSettingsKey.WebsiteName]</div>

                        @if (hasTagline)
                        {
                            <small class="brand-tagline">@tagline</small>
                        }
                    </div>
                </a>
                <button class="navbar-toggler border-0 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-expanded="false">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="navbar-collapse collapse" id="mainNav" style="">
                    <div class="navbar-right">
                        <ul class="navbar-nav nav-categories">

                            <li class="nav-item">
                                <a class="nav-link" href="/">Beranda</a>
                            </li>

                            @if (ViewData["NavbarItems"] as List<NavbarItem> != null)
                            {
                                @foreach (var nav in (ViewData["NavbarItems"] as List<NavbarItem>))
                                {
                                        @if(nav.SubItems.Count == 0)
                                        {
                                        <li class="nav-item">
                                            <a class="nav-link" href="@nav.Url">@nav.Title</a>
                                        </li>
                                        }
                                        else
                                        {
                                        <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle"
                                                   href="#"
                                                   data-bs-toggle="dropdown">
                                                @nav.Title
                                            </a>

                                            <ul class="dropdown-menu">
                                                @if (!nav.Url.StartsWith("/Article/"))
                                                {
                                                    
                                                    <li>
                                                        <a class="dropdown-item"
                                                               href="@(nav.Url)">
                                                            <strong>Semua @nav.Title</strong>
                                                        </a>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                }


                                                @foreach (var sub in nav.SubItems)
                                                {
                                                    <li>
                                                        <a class="dropdown-item"
                                                               href="@sub.Url">
                                                            @sub.Title
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </li>
                                        }
                                }
                            }
                            <div class="navbar-search-wrapper" id="navSearch">
                                <button type="button" class="btn btn-link p-0 search-toggle">
                                    <i class="bi bi-search"></i>
                                </button>

                                <form class="navbar-search-expand" action="/Search" method="GET">
                                    <input class="form-control" type="text" name="query" placeholder="Cari berita..." autocomplete="off" />
        
                                    <button type="submit" class="btn-search">
                                        <i class="bi bi-search"></i>
                                    </button>

                                    <button type="button" class="btn-clear">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </form>
                            </div>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 footer-about">
                    <h5><i class="bi bi-mortarboard-fill me-2"></i>@ViewData[ServerSettingsKey.WebsiteName]</h5>
                    @if(ViewData[ServerSettingsKey.FooterDescription] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.FooterDescription].ToString()))
                    {
                        <p>@ViewData[ServerSettingsKey.FooterDescription]</p>
                    }
                    <div class="footer-social mt-3">
                        @if(ViewData[ServerSettingsKey.FacebookUrl] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.FacebookUrl].ToString()))
                        {
                            <a href="@ViewData[ServerSettingsKey.FacebookUrl]" target="_blank" class="me-2">
                                <i class="bi bi-facebook"></i>
                            </a>
                        }
                        @if(ViewData[ServerSettingsKey.InstagramUrl] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.InstagramUrl].ToString()))
                        {
                            <a href="@ViewData[ServerSettingsKey.InstagramUrl]" target="_blank" class="me-2">
                                <i class="bi bi-instagram"></i>
                                                            </a>
                        }
                        @if(ViewData[ServerSettingsKey.TiktokUrl] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.TiktokUrl].ToString()))
                        {
                            <a href="@ViewData[ServerSettingsKey.TiktokUrl]" target="_blank" class="me-2">
                                <i class="bi bi-tiktok"></i>
                            </a>
                        }
                        @if(ViewData[ServerSettingsKey.YoutubeUrl] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.YoutubeUrl].ToString()))
                        {
                            <a href="@ViewData[ServerSettingsKey.YoutubeUrl]" target="_blank" class="me-2">
                                <i class="bi bi-youtube"></i>
                            </a>
                        }
                        @if(ViewData[ServerSettingsKey.TwitterUrl] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.TwitterUrl].ToString()))
                        {
                            <a href="@ViewData[ServerSettingsKey.TwitterUrl]" target="_blank" class="me-2">
                                <i class="bi bi-twitter"></i>
                            </a>
                        }
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5>Kategori</h5>
                    <ul class="list-unstyled footer-links">
                        @if (ViewData["NavbarItems"] as List<NavbarItem> != null)
                        {
                            @foreach (var nav in (ViewData["NavbarItems"] as List<NavbarItem>))
                            {
                                <li><a href="@nav.Url">@nav.Title</a></li>
                            }
                        }
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5>Kontak</h5>
                    <ul class="list-unstyled footer-contact">
                        @if (ViewData[ServerSettingsKey.FooterAddress] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.FooterAddress].ToString()))
                        {
                            <li><i class="bi bi-geo-alt-fill"></i><span>@ViewData[ServerSettingsKey.FooterAddress]</span></li>
                        }
                        @if(ViewData[ServerSettingsKey.FooterPhone] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.FooterPhone].ToString()))
                        {
                            <li><i class="bi bi-telephone-fill"></i><span>@ViewData[ServerSettingsKey.FooterPhone]</span></li>
                        }
                        @if(ViewData[ServerSettingsKey.FooterEmail] != null && !string.IsNullOrEmpty(ViewData[ServerSettingsKey.FooterEmail].ToString()))
                        {
                            <li><i class="bi bi-envelope-fill"></i><span>@ViewData[ServerSettingsKey.FooterEmail]</span></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container position-relative">
        
                <!-- perfectly centered -->
                <div class="text-center">
                    &copy; @DateTime.Now.ToString("yyyy")
                    @ViewData[ServerSettingsKey.WebsiteName]. All rights reserved. - Powered By
                    <a href="https://www.linkedin.com/in/rahmad-syaputra/">Putra3340</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            document.documentElement.style.setProperty('--primary', '@PrimaryColor');
            document.documentElement.style.setProperty('--primary-light', '@Adjust(PrimaryColor, 20)');
            document.documentElement.style.setProperty('--primary-lighter', '@Adjust(PrimaryColor, 40)');
            document.documentElement.style.setProperty('--primary-lightest', '@Adjust(PrimaryColor, 70)');
            document.documentElement.style.setProperty('--primary-dark', '@Adjust(PrimaryColor, -15)');
            document.documentElement.style.setProperty('--primary-darker', '@Adjust(PrimaryColor, -30)');

            document.documentElement.style.setProperty('--accent', '@AccentColor');
            document.documentElement.style.setProperty('--accent-light', '@Adjust(AccentColor, 25)');
            document.documentElement.style.setProperty('--accent-dark', '@Adjust(AccentColor, 25)');
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
