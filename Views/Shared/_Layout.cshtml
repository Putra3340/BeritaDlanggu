@{
    string PrimaryColor = ViewData[ServerSettingsKey.ThemeColor] as string;
    string AccentColor = ViewData[ServerSettingsKey.ThemeAccentColor] as string;
    string Adjust(string hex, int percent)
    {
        hex = hex.Replace("#", "");
        int r = Convert.ToInt32(hex.Substring(0, 2), 16);
        int g = Convert.ToInt32(hex.Substring(2, 2), 16);
        int b = Convert.ToInt32(hex.Substring(4, 2), 16);

        int AdjustChannel(int c)
        {
            return Math.Clamp(c + (int)(percent / 100.0 * 255), 0, 255);
        }

        r = AdjustChannel(r);
        g = AdjustChannel(g);
        b = AdjustChannel(b);

        return $"#{r:X2}{g:X2}{b:X2}";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO META -->
    <title>@ViewData["MetaTitle"]</title>
    <meta name="description" content="@ViewData["MetaDesc"]">
    <meta name="keywords" content="@ViewData["MetaKeyword"]">
    <meta name="author" content="@ViewData["MetaAuthor"]">
    <meta name="robots" content="@ViewData["MetaRobot"]">
    <!-- Open Graph (Facebook, Discord, etc.) -->
    <meta property="og:title" content="@ViewData["MetaTitle"]">
    <meta property="og:description" content="@ViewData["MetaDesc"]">
    <meta property="og:image" content="@ViewData["MetaImage"]">
    <meta property="og:url" content="@ViewData["MetaUrl"]">
    <meta property="og:type" content="@ViewData["MetaType"]">
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@ViewData["MetaTitle"]">
    <meta name="twitter:description" content="@ViewData["MetaDesc"]">
    <meta name="twitter:image" content="@ViewData["MetaImage"]">

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body>
    <div id="navbar-container" data-active="">
        <nav class="navbar navbar-expand-lg main-navbar">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <img src="~/icon-dlanggu.png"
                         style="width:42px;height:42px;object-fit:contain;border-radius:10px;" />
                    <div>
                        <div style="line-height:0.1;margin-top:10%">@ViewData[ServerSettingsKey.WebsiteName]</div>
                        <small style="font-size:10px;color:var(--text-muted);font-weight:400">@ViewData[ServerSettingsKey.TagLine]</small>
                    </div>
                </a>
                <button class="navbar-toggler border-0 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-expanded="false">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="navbar-collapse collapse" id="mainNav" style="">
                    <ul class="navbar-nav ms-auto me-3">

                        <li class="nav-item"><a class="nav-link " href="/">Beranda</a></li>
                        @if (ViewData["CatList"] as List<Categories> != null)
                        {
                            @foreach (var cat in (ViewData["CatList"] as List<Categories>).Take(4))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">@cat.Name</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" href="/Kategori/@cat.Slug"><strong>Semua @cat.Name</strong></a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        @foreach (var sub in cat.SubCategories)
                                        {
                                            <li><a class="dropdown-item" href="/Kategori/@cat.Slug/@sub.Slug">@sub.Name</a></li>
                                        }
                                    </ul>
                                </li>
                            }
                        }
                    </ul>
                    <form class="navbar-search d-none d-lg-block" action="/Search" method="GET">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" name="query" placeholder="Cari berita..." autocomplete="off">
                    </form>
                </div>
            </div>
        </nav>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 footer-about">
                    <h5><i class="bi bi-mortarboard-fill me-2"></i>@ViewData[ServerSettingsKey.WebsiteName]</h5>
                    <p>Portal berita resmi SMKN 1 Dlanggu yang menyajikan informasi terkini seputar kegiatan sekolah, prestasi siswa, pengumuman, dan berbagai agenda penting.</p>
                    <div class="footer-social mt-3">
                        <a href="#" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" title="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" title="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" title="Twitter"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5>Kategori</h5>
                    <ul class="list-unstyled footer-links">
                        @if (ViewData["CatList"] as List<Categories> != null)
                        {
                            @foreach (var cat in (ViewData["CatList"] as List<Categories>).Take(4))
                            {
                                <li><a href="/Kategori/@cat.Slug">@cat.Name</a></li>
                            }
                        }
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h5>Kontak</h5>
                    <ul class="list-unstyled footer-contact">
                        <li><i class="bi bi-geo-alt-fill"></i><span>Jl. Raya Dlanggu, Kec. Dlanggu, Kab. Mojokerto, Jawa Timur</span></li>
                        <li><i class="bi bi-telephone-fill"></i><span>(0321) 123456</span></li>
                        <li><i class="bi bi-envelope-fill"></i><span>info@smkn1dlanggu.sch.id</span></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container position-relative">
        
                <!-- perfectly centered -->
                <div class="text-center">
                    &copy; @DateTime.Now.ToString("yyyy")
                    @ViewData[ServerSettingsKey.WebsiteName]. All rights reserved.
                </div>

                <!-- right side -->
                <div class="position-absolute top-50 end-0 translate-middle-y">
                    Powered By
                    <a href="https://www.linkedin.com/in/rahmad-syaputra/">Putra3340</a>
                </div>

            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            document.documentElement.style.setProperty('--primary', '@PrimaryColor');
            document.documentElement.style.setProperty('--primary-light', '@Adjust(PrimaryColor, 20)');
            document.documentElement.style.setProperty('--primary-lighter', '@Adjust(PrimaryColor, 40)');
            document.documentElement.style.setProperty('--primary-lightest', '@Adjust(PrimaryColor, 70)');
            document.documentElement.style.setProperty('--primary-dark', '@Adjust(PrimaryColor, -15)');
            document.documentElement.style.setProperty('--primary-darker', '@Adjust(PrimaryColor, -30)');

            document.documentElement.style.setProperty('--accent', '@AccentColor');
            document.documentElement.style.setProperty('--accent-light', '@Adjust(AccentColor, 25)');
            document.documentElement.style.setProperty('--accent-dark', '@Adjust(AccentColor, 25)');
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
