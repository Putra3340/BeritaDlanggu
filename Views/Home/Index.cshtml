@model BeritaDlanggu.Models.ViewModels.HomeViewModel;
@{
    string ToRelativeTime(DateTime input)
    {
        var ts = DateTime.Now - input;

        if (ts.TotalSeconds < 60)
            return $"{(int)ts.TotalSeconds} detik lalu";

        if (ts.TotalMinutes < 60)
            return $"{(int)ts.TotalMinutes} menit lalu";

        if (ts.TotalHours < 24)
            return $"{(int)ts.TotalHours} jam lalu";

        if (ts.TotalDays < 7)
            return $"{(int)ts.TotalDays} hari lalu";

        if (ts.TotalDays < 30)
            return $"{(int)(ts.TotalDays / 7)} minggu lalu";

        if (ts.TotalDays < 365)
            return $"{(int)(ts.TotalDays / 30)} bulan lalu";

        return $"{(int)(ts.TotalDays / 365)} tahun lalu";
    }
}
<section class="container mt-4">
    <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="@(int.Parse(ViewData[ServerSettingsKey.TimerSlider]?.ToString() ?? "5") * 1000)">
        <div class="carousel-indicators" id="carouselIndicators">
            @for (int i = 0; i < Model.FeaturedArticles.Count; i++)
            {
                <button type="button"
                        data-bs-target="#heroCarousel"
                        data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        aria-current="@(i == 0 ? "true" : null)">
                </button>
            }
        </div>
        <div class="carousel-inner" id="carouselInner">
            @{
                var index = 0;
            }
            @foreach (var item in Model.FeaturedArticles)
            {
                <div class="carousel-item @(index == 0 ? "active" : "")">
                    <div class="image-16by9">
                        <img src="@item.Banner" alt="@item.Title">
                    </div>
                    <div class="carousel-overlay">
                        <span class="category-badge">@item.CategoryName</span>
                        <h2>@item.Title</h2>
                        <p>@item.Content</p>
                        <div class="meta">
                            <i class="bi bi-person me-1"></i>@item.AuthorName •
                            <i class="bi bi-clock ms-2 me-1"></i>@item.CreatedAt.ToString("d MMMM yyyy")
                        </div>
                        <a href="/Article/@item.Slug" class="btn btn-primary btn-sm mt-1">
                            Baca Selengkapnya <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                index++;
            }

        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>
<section class="container mt-4">
    <div class="row">
        <!-- News Grid -->
        <div class="col-lg-8">
            <div class="section-header">
                <h2>Berita Terbaru</h2>
                <a href="category.html" class="view-all">Lihat Semua <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="row" id="newsGrid">
                @foreach (var article in Model.LatestArticles)
                {
                    <div class="col-md-6 col-lg-4 mb-4 fade-in">
                        <div class="news-card">
                            <div class="card-img-wrapper">
                                <img src="@article.Banner" alt="@article.Title" loading="lazy">
                                <span class="category-badge">@article.CategoryName</span>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title"><a href="/Article/@article.Slug">@article.Title</a></h5>
                                <p class="card-excerpt">@article.Content...</p>
                                <div class="card-meta d-flex flex-column align-items-start text-start">
                                    <span>
                                        <i class="bi bi-person me-1"></i>@article.AuthorName
                                    </span>

                                    <div class="d-flex gap-3">
                                        <span>
                                            <i class="bi bi-clock me-1"></i>@article.CreatedAt.ToString("dd MMMM yyyy")
                                        </span>
                                        <span>
                                            <i class="bi bi-eye me-1"></i>@article.ViewsCount
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Trending -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title">Trending</h5>
                <div id="trendingList">
                    @{
                        int trendingtop = 0;
                    }
                    @foreach (var item in Model.TrendingArticles)
                    {
                        trendingtop++;
                        <div class="sidebar-item">
                            <span class="item-number">@trendingtop</span>
                            <div class="item-content">
                                <h6><a href="/Article/@item.Slug">@item.Title</a></h6>
                                <span class="item-meta"><i class="bi bi-eye me-1"></i>@item.ViewsCount.ToString() views • @item.CreatedAt.ToString("d MMMM yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Pengumuman -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title">Pengumuman</h5>
                <div id="announcementList">
                    @foreach (var item in Model.AnnouncementArticles)
                    {
                        
                        <div class="announcement-item">
                            <span class="ann-badge">Pengumuman</span>
                            <h6><a href="/Article/@item.Slug">@item.Title</a></h6>
                            <p><i class="bi bi-clock me-1"></i>@item.CreatedAt.ToString("d MMMM yyyy")</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Kategori -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title">Kategori</h5>
                <div class="category-chips">
                    @if (ViewData["CatList"] as List<Categories> != null)
                    {
                        @foreach (var cat in ViewData["CatList"] as List<Categories>)
                        {
                            <a href="/Kategori/@cat.Slug" class="category-chip">
                                @cat.Name
                                <span class="ms-1 opacity-50">(@cat.SubCategories.Count())</span>
                            </a>
                        
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>