@model BeritaDlanggu.Models.ViewModels.HomeViewModel;
@{
    string ToRelativeTime(DateTime input)
    {
        var ts = DateTime.Now - input;

        if (ts.TotalSeconds < 60)
            return $"{(int)ts.TotalSeconds} detik lalu";

        if (ts.TotalMinutes < 60)
            return $"{(int)ts.TotalMinutes} menit lalu";

        if (ts.TotalHours < 24)
            return $"{(int)ts.TotalHours} jam lalu";

        if (ts.TotalDays < 7)
            return $"{(int)ts.TotalDays} hari lalu";

        if (ts.TotalDays < 30)
            return $"{(int)(ts.TotalDays / 7)} minggu lalu";

        if (ts.TotalDays < 365)
            return $"{(int)(ts.TotalDays / 30)} bulan lalu";

        return $"{(int)(ts.TotalDays / 365)} tahun lalu";
    }
}
<section class="container mt-4">
    <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-indicators" id="carouselIndicators">
            @for (int i = 0; i < Model.FeaturedArticles.Count; i++)
            {
                <button type="button"
                        data-bs-target="#heroCarousel"
                        data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        aria-current="@(i == 0 ? "true" : null)">
                </button>
            }
        </div>
        <div class="carousel-inner" id="carouselInner">
            @{
                var index = 0;
            }
            @foreach (var item in Model.FeaturedArticles)
            {
                <div class="carousel-item @(index == 0 ? "active" : "")">
                    <img src="@item.Banner" alt="@item.Title">
                    <div class="carousel-overlay">
                        <span class="category-badge">@item.CategoryName</span>
                        <h2>@item.Title</h2>
                        <p>@item.Content</p>
                        <div class="meta">
                            <i class="bi bi-person me-1"></i>@item.AuthorName •
                            <i class="bi bi-clock ms-2 me-1"></i>@item.CreatedAt.ToString("d MMMM yyyy")
                        </div>
                        <a href="Article?id=@item.Id" class="btn btn-primary btn-sm mt-3">
                            Baca Selengkapnya <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                index++;
            }

        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>
<section class="container mt-4">
    <div class="row">
        <!-- News Grid -->
        <div class="col-lg-8">
            <div class="section-header">
                <h2><i class="bi bi-newspaper me-2"></i>Berita Terbaru</h2>
                <a href="category.html" class="view-all">Lihat Semua <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="row" id="newsGrid">
                
            </div>
            <div class="pagination">
                <button onclick="loadPage(1)">1</button>
                <button onclick="loadPage(2)">2</button>
                <button onclick="loadPage(3)">3</button>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Trending -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title"><i class="bi bi-fire me-2 text-danger"></i>Trending</h5>
                <div id="trendingList">
                    @{
                        int trendingtop = 0;
                    }
                    @foreach (var item in Model.TrendingArticles)
                    {
                        trendingtop++;
                        <div class="sidebar-item">
                            <span class="item-number">@trendingtop</span>
                            <div class="item-content">
                                <h6><a href="article.html?id=@item.Id">@item.Title</a></h6>
                                <span class="item-meta"><i class="bi bi-eye me-1"></i>@item.ViewsCount.ToString() views • @item.CreatedAt.ToString("d MMMM yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Pengumuman -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title"><i class="bi bi-megaphone-fill me-2 text-warning"></i>Pengumuman</h5>
                <div id="announcementList">
                    @foreach (var item in Model.AnnouncementArticles)
                    {
                        
                        <div class="announcement-item">
                            <span class="ann-badge">Pengumuman</span>
                            <h6><a href="article.html?id=@item.Id">@item.Title</a></h6>
                            <p><i class="bi bi-clock me-1"></i>@item.CreatedAt.ToString("d MMMM yyyy")</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Kategori -->
            <div class="sidebar-widget slide-up">
                <h5 class="widget-title"><i class="bi bi-tags-fill me-2"></i>Kategori</h5>
                <div id="categoryList" class="category-chips"><a href="category.html?cat=berita-sekolah" class="category-chip">Berita Sekolah <span class="ms-1 opacity-50">(4)</span></a><a href="category.html?cat=prestasi" class="category-chip">Prestasi <span class="ms-1 opacity-50">(3)</span></a><a href="category.html?cat=pengumuman" class="category-chip">Pengumuman <span class="ms-1 opacity-50">(3)</span></a><a href="category.html?cat=ekstrakurikuler" class="category-chip">Ekstrakurikuler <span class="ms-1 opacity-50">(3)</span></a><a href="category.html?cat=agenda" class="category-chip">Agenda <span class="ms-1 opacity-50">(0)</span></a></div>
            </div>
        </div>
    </div>
</section>
<script id="b3v9t9">
    async function loadPage(page) {
        const grid = document.getElementById("newsGrid");

        // fade out
        grid.classList.add("fade-out");

        setTimeout(async () => {
            const res = await fetch(`/Home/GetArticles?page=${page}`);
            const data = await res.json();

            let html = "";

            data.forEach(item => {
                html += `
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="news-card">
                        <div class="card-img-wrapper">
                            <img src="${item.banner}" loading="lazy">
                            <span class="category-badge">${item.categoryName}</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="article.html?id=${item.id}">${item.title}</a>
                            </h5>
                            <p>${item.content}</p>
                        </div>
                    </div>
                </div>`;
            });

            grid.innerHTML = html;

            // fade in
            grid.classList.remove("fade-out");
            grid.classList.add("fade-in");

        }, 300);
    }
</script>