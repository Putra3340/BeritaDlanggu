@using BeritaDlanggu.Models.ViewModels
@model CategoryViewModel
<section class="container mt-4 mb-5">
    <!-- Category Header -->
    <div class="category-header fade-in" id="categoryHeader">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2" style="--bs-breadcrumb-divider-color:rgba(255,255,255,0.5)">
                <li class="breadcrumb-item"><a href="/" style="color:rgba(255,255,255,0.8)">Beranda</a></li>
                <li class="breadcrumb-item active" style="color:#fff" id="breadcrumbCat">@(Model.CurrentCategory != null ? Model.CurrentCategory.Name : "Kategori")</li>
            </ol>
        </nav>
        <h1 id="categoryTitle">@(Model.CurrentCategory != null ? Model.CurrentCategory.Name : "Semua Berita")@(Model.CurrentSubCategory != null ? $" - {Model.CurrentSubCategory.Name}" : "")</h1>
        <p id="categoryDesc">@(Model.CurrentCategory != null ? Model.CurrentCategory.Name : "Menampilkan semua berita terbaru dari SMKN 1 Dlanggu")</p>
    </div>

    @if (Model.CurrentCategory != null)
    {
        <!-- Subcategory Chips -->
        <div class="category-chips mt-3 mb-2" id="subcategoryChips">
            @if (Model.CurrentSubCategory == null)
            {
                <a href="/Kategori/@Model.CurrentCategory.Slug" class="category-chip active">Semua</a>
            }
            else
            {
                <a href="/Kategori/@Model.CurrentCategory.Slug" class="category-chip">Semua</a>
            }

            @foreach (var subcat in Model.CurrentCategory.SubCategories)
            {
                @if (Model.CurrentSubCategory != null)
                {
                    if (subcat.Slug == Model.CurrentSubCategory.Slug)
                    {
                        <a href="/Kategori/@Model.CurrentCategory.Slug/@subcat.Slug" class="category-chip active">@subcat.Name</a>
                    }
                    else
                    {
                        <a href="/Kategori/@Model.CurrentCategory.Slug/@subcat.Slug" class="category-chip ">@subcat.Name</a>
                    }
                }
                else
                {
                    <a href="/Kategori/@Model.CurrentCategory.Slug/@subcat.Slug" class="category-chip ">@subcat.Name</a>
                }
            }
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="row" id="newsGrid">
                @await Html.PartialAsync("_NewsGrid", Model.Articles)
            </div>
            <div class="text-center mt-4">
                <button class="btn btn-primary px-4"
                        id="loadMoreBtn">
                    Load More
                </button>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="sidebar-widget">
                <h5 class="widget-title"><i class="bi bi-tags-fill me-2"></i>Semua Kategori</h5>
                <div id="allCategories">
                    @foreach (var cat in Model.Categories)
                    {
                        <div class="sidebar-item">
                            <div class="item-content" style="flex:1">
                                <h6><a href="/Kategori/@cat.Slug">@cat.Name</a></h6>
                                <span class="item-meta">@cat.Articles.Count() berita</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    let currentPage = 1;
    let loading = false;
        const cat = @Model.CurrentCategory?.Id;
        const subcat = @(Model.CurrentSubCategory?.Id ?? 0);
    async function loadMore() {

        if (loading) return;

        loading = true;

        currentPage++;

        const btn = document.getElementById("loadMoreBtn");

        btn.innerHTML = "Loading...";

        try {

                const response = await fetch(`/Category/LoadMoreArticles?page=${currentPage}&cat=${cat}&subcat=${subcat}`);

            const html = await response.text();

            if (html.trim() === "") {
                btn.remove();
                return;
            }

            document
                .getElementById("newsGrid")
                .insertAdjacentHTML("beforeend", html);

            btn.innerHTML = "Load More";

        } catch {

            btn.innerHTML = "Failed";

        }

        loading = false;
    }

    document
        .getElementById("loadMoreBtn")
        .addEventListener("click", loadMore);
</script>