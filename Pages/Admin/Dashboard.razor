@page "/Admin"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject BeritaDlangguNetContext Db
@inject AuthenticationStateProvider AuthStateProvider

<div class="dashboard-topbar">
    <div>
        <h4>Admin Dashboard</h4>
        <p class="text-muted mb-0 small">Ringkasan sistem dan aktivitas terkini</p>
    </div>
    <div class="user-info">
        <span id="adminName" class="d-none d-md-inline">@(user?.Identity?.Name ?? "Admin")</span>
        <div class="user-avatar" id="adminAvatar">@(user?.Identity?.Name?[0] ?? 'A')</div>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="bi bi-file-earmark-text"></i></div>
            <div class="stat-value" id="statArticles">@TotalArticle</div>
            <div class="stat-label">Total Artikel</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-people"></i></div>
            <div class="stat-value" id="statUsers">@TotalUser</div>
            <div class="stat-label">Total User</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-tags"></i></div>
            <div class="stat-value" id="statCategories">@TotalKategori</div>
            <div class="stat-label">Kategori</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-eye"></i></div>
            <div class="stat-value" id="statTotalViews">@TotalViews</div>
            <div class="stat-label">Total Views</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Articles -->
    <div class="col-lg-7">
        <div class="settings-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="fw-bold mb-0">Artikel Terbaru</h5>
                <a href="/Admin/Article" class="small fw-semibold text-primary">Lihat Semua →</a>
            </div>
            @foreach (var item in LatestArticle)
            {
                <div class="sidebar-item">
                    <div class="item-thumb">
                        <img src="@item.ThumbnailUrl" alt="@item.Title">
                    </div>
                    <div class="item-content" style="flex:1">
                        <h6><a href="/Article/@item.Slug">@item.Title</a></h6>
                        <span class="item-meta">
                            <span class="status-badge @(item.Status == (int)ArticleStatus.Draft ? "draft" : "published")" style="font-size:10px;padding:2px 8px">@(item.Status == (int)ArticleStatus.Draft ? "Draft" : "Published")</span>
                            • @ToRelativeTime(item.CreatedAt)
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Activity Log -->
    <div class="col-lg-5">
        <div class="settings-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="fw-bold mb-0">Aktivitas Terkini</h5>
                <a href="logs.html" class="small fw-semibold text-primary">Lihat Semua →</a>
            </div>
            @if (activityList == null || activityList.Count == 0)
            {
                <div class="empty-state"><i class="bi bi-clock-history"></i><h5>Tidak ada log</h5></div>
            }
            else
            {
                @foreach (var log in activityList)
                {
                    <div class="log-item">
                        <div class="log-icon @log.Action">
                            @if (log.Action == "login")
                            {
                                <i class="bi bi-box-arrow-in-right"></i>
                            }
                            else if (log.Action == "create")
                            {
                                <i class="bi bi-plus-circle"></i>
                            }
                            else if (log.Action == "update")
                            {
                                <i class="bi bi-pencil-square"></i>
                            }
                            else if (log.Action == "delete")
                            {
                                <i class="bi bi-trash"></i>
                            }
                            )
                        </div>
                        <div class="log-content" style="flex:1">
                            <h6>@log.Details</h6>
                            <p><i class="bi bi-person me-1"></i>@log.User.Username • <i class="bi bi-clock ms-1 me-1"></i>@ToRelativeTime(log.Timestamp)</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
@code {
    private List<BeritaDlanggu.Models.Articles> LatestArticle;

    private int TotalArticle = 0;
    private int TotalUser = 0;
    private int TotalKategori = 0;
    private int TotalViews = 0;
    private ClaimsPrincipal? user;


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        user = authState.User;
        LatestArticle = Db.Articles
    .Where(a => a.Status == (byte)ArticleStatus.Published)
    .OrderByDescending(a => a.CreatedAt)
    .Take(5)
    .ToList();

        TotalArticle = Db.Articles.Where(a => a.Status == (int)ArticleStatus.Published).Count();
        TotalUser = Db.Users.Where(x=>x.IsActive == true).Count();
        TotalKategori = Db.Categories.Count() + Db.SubCategories.Count();
        TotalViews = Db.Articles.Sum(x => x.Views);
        activityList = Db.ActivityLogs.Include(x => x.User).OrderByDescending(a => a.Timestamp).Take(5).ToList();

    }

    public string ToRelativeTime(DateTime input)
    {
        var ts = DateTime.Now - input;

        if (ts.TotalSeconds < 60)
            return $"{(int)ts.TotalSeconds} detik lalu";

        if (ts.TotalMinutes < 60)
            return $"{(int)ts.TotalMinutes} menit lalu";

        if (ts.TotalHours < 24)
            return $"{(int)ts.TotalHours} jam lalu";

        if (ts.TotalDays < 7)
            return $"{(int)ts.TotalDays} hari lalu";

        if (ts.TotalDays < 30)
            return $"{(int)(ts.TotalDays / 7)} minggu lalu";

        if (ts.TotalDays < 365)
            return $"{(int)(ts.TotalDays / 30)} bulan lalu";

        return $"{(int)(ts.TotalDays / 365)} tahun lalu";
    }
}
@code {
    private List<ActivityLogs> activityList;
    private string FilterAction
    {
        get; set
        {
            field = value;
            activityList = Db.ActivityLogs.Include(x => x.User).Where(x => x.Action.Contains(field)).OrderByDescending(a => a.Timestamp).ToList();
        }
    } = "";
}