@page "/Editor/ArticleForm/{Id:int?}"
@layout EditorLayout
@attribute [Authorize(Roles = "Editor")]
@inject BeritaDlangguNetContext Db
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationService Notif
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor

<div class="dashboard-topbar">
    <div>
        <h4>@(Id == null ? "Tulis Artikel Baru" : "Edit Artikel")</h4>
        <p class="text-muted mb-0 small">Buat konten menarik untuk pembaca</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-sm" id="previewBtn" @onclick="OpenPreview"><i class="bi bi-eye me-1"></i>Preview</button>
        <a href="/Admin/Article" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Kembali</a>
    </div>
</div>
<div class="row g-4">
    <div class="col-lg-8">
        <!-- Title -->
        <div class="settings-card">
            <div class="mb-3">
                <label class="form-label fw-semibold">Judul Artikel</label>
                <input type="text" class="form-control form-control-lg" id="articleTitle" placeholder="Masukkan judul artikel yang menarik..." required @bind="article.Title">
            </div>

            <!-- Content Editor -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Konten Artikel</label>
                <RichTextEditor @bind-Value="article.Content" />
            </div>
                
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Publish Settings -->
        <div class="settings-card">
            <h5><i class="bi bi-gear me-2"></i>Pengaturan</h5>

            <div class="mb-3">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select" @bind="article.Status" required>
                    @foreach (var status in Enum.GetValues<ArticleStatus>())
                    {
                        <option value="@((int)status)">@status</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Kategori</label>
                <select class="form-select" id="articleCategory" required @bind="SelectedCategoryId">
                    <option value="0">Pilih Kategori</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Sub-Kategori</label>
                <select class="form-select" id="articleSubcategory" @bind="SelectedSubCategoryId">
                    <option value="0">Pilih Sub-Kategori</option>
                    @foreach (var subcat in subcategories)
                    {
                        <option value="@subcat.Id">@subcat.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="articleFeatured" @bind="article.IsFeatured">
                    <label class="form-check-label fw-semibold">Artikel Unggulan</label>
                </div>
            </div>
        </div>

        <!-- Image -->
        <div class="settings-card">
            <h5><i class="bi bi-image me-2"></i>Gambar Utama</h5>

            <div class="mb-3">
                <label class="form-label fw-semibold">Upload Gambar</label>
                <InputFile class="form-control"
                           accept="image/*"
                           OnChange="OnImageSelected" />

                <div class="form-text">
                    Hanya file gambar dari perangkat
                </div>
            </div>

            @if (!string.IsNullOrEmpty(imagePreviewUrl))
            {
                <div class="mt-2">
                    <img src="@imagePreviewUrl"
                         class="rounded"
                         style="width:100%;height:160px;object-fit:cover" />
                </div>
            }
        </div>

        <!-- Excerpt -->
        <div class="settings-card">
            <h5><i class="bi bi-text-left me-2"></i>Ringkasan</h5>
            <textarea class="form-control" id="articleExcerpt" rows="3" placeholder="Ringkasan singkat artikel (opsional)" @bind="article.Excerpt"></textarea>
        </div>

        <!-- Actions -->
        <div class="d-grid gap-2">
            <button class="btn btn-primary" @onclick="SaveArticle"><i class="bi bi-check-circle me-2"></i>Simpan Artikel</button>
            <button type="button" class="btn btn-outline-secondary" onclick="window.location.href='/Admin/Article'"><i class="bi bi-x-circle me-2"></i>Batal</button>
        </div>
    </div>
</div>
<!-- Preview Modal -->
<div class="modal fade preview-modal @(IsPreviewShow ? "show d-block" : "")" tabindex="-1"
     style="background-color:@(IsPreviewShow ? "rgba(0,0,0,0.5)" : "transparent")">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Preview Artikel</h5>
                <button type="button" class="btn-close" @onclick="ClosePreview"></button>
            </div>
            <div class="modal-body">
                <div class="article-page">
                    <div class="article-header">
                        <span class="article-category">@PreviewCategoryName</span>
                        <h1 style="font-size:1.5rem">@article.Title</h1>
                    </div>
                    <div class="article-featured-img"><img src="@imagePreviewUrl" alt="@article.Title"></div>
                    <div class="article-content">
                        @((MarkupString)PreviewContent)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@code{
    private bool IsPreviewShow = false;
    private string PreviewContent = "";
    private string PreviewCategoryName = "KATEGORI BELUM DIPILIH";
    private void OpenPreview()
    {
        PreviewContent = article.Content;
        if(SelectedCategoryId != 0)
            PreviewCategoryName = Db.Categories.Find(SelectedCategoryId).Name;
        IsPreviewShow = true;
    }
    private void ClosePreview()
    {
        IsPreviewShow = false;
        
    }
}
@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? Id { get; set; }
    private bool IsEdit = false;
    private Articles article;

    private List<BeritaDlanggu.Models.Categories> categories;
    private List<BeritaDlanggu.Models.SubCategories> subcategories;
    private int SelectedCategoryId { get; set { field = value; subcategories = Db.SubCategories.Where(x => x.ParentId == value).ToList(); } }
    private int SelectedSubCategoryId;


    private string imagePreviewUrl;
    private IBrowserFile selectedImage;

    private ClaimsPrincipal? user;

    protected override async Task OnInitializedAsync()
    {
        if(Id != null)
        {
            article = Db.Articles
    .Include(x => x.Cat)
    .Include(c => c.SubCat)
    .FirstOrDefault(x => x.Id == Id);
            if(article != null)
            {
                IsEdit = true;
                SelectedCategoryId = article.Cat.Id;
                SelectedSubCategoryId = article.SubCat != null ? article.SubCat.Id : 0;
                imagePreviewUrl = article.ThumbnailUrl;
            }
        }
        if (article == null)
            article = new();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        user = authState.User;

        categories = Db.Categories.ToList();
        subcategories = Db.SubCategories.ToList();

        // Load categories and subcategories from database
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        selectedImage = e.File;

        using var stream = selectedImage.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();

        await stream.CopyToAsync(ms);
        var buffer = ms.ToArray();

        imagePreviewUrl = $"data:{selectedImage.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async void SaveArticle()
    {
        try
        {
            if(Id != null) // EDIT CHANGES
            {
                // title and slug
                if (article.Title == null || article.Title.Length == 0)
                {
                    Notif.Show("Judul artikel harus di isi!", "error");
                    return;
                }
                article.Slug = article.Title.GenerateSlug();
                if (Db.Articles.Any(x => x.Slug == article.Slug || x.Title == article.Title))
                {
                    Notif.Show("Judul Berita Sudah ada, silahkan gunakan judul lain!", "error");
                }
                if (selectedImage != null)
                {
                    var fileName = $"{Guid.NewGuid()}{Path.GetExtension(selectedImage.Name)}";
                    var folderPath = Path.Combine(Env.WebRootPath, "uploads", "thumbnails");

                    if (!Directory.Exists(folderPath))
                        Directory.CreateDirectory(folderPath);

                    var filePath = Path.Combine(folderPath, fileName);

                    using var stream = selectedImage.OpenReadStream(5 * 1024 * 1024);
                    using var fs = new FileStream(filePath, FileMode.Create);
                    await stream.CopyToAsync(fs);

                    // save path to DB
                    article.ThumbnailUrl = $"/uploads/thumbnails/{fileName}";
                }
                // excerpt
                if (string.IsNullOrWhiteSpace(article.Excerpt))
                {
                    article.Excerpt = article.Title != null && article.Title.Length > 100 ? article.Title.Substring(0, 100) + "..." : article.Title;
                }
                article.MetaTitle = article.Title;
                article.MetaDescription = article.Excerpt;

                article.AuthorId = int.Parse(user.FindFirst("Id")?.Value);
                article.UpdatedAt = DateTime.Now;

                if (article.Status == (int)ArticleStatus.Published)
                {
                    article.PublishedAt = DateTime.Now;
                }
                var catedit = Db.Categories.Find(SelectedCategoryId);
                if (catedit == null)
                {
                    Notif.Show("Kategori tidak ada!", "error");
                    return;
                }
                article.Cat = catedit;
                var subcatedit = Db.SubCategories.Find(SelectedSubCategoryId);
                if (subcatedit != null)
                    article.SubCat = subcatedit;

                Db.Articles.Attach(article);
                Db.Entry(article).State = EntityState.Modified;
                Db.SaveChanges();
                // Activity Log
                var activityedit = new ActivityLogs
                {
                    Action = "update",
                    Details = "Mengedit artikel: " + article.Title,
                    IpAddress = HttpContextAccessor.HttpContext?.Connection?.RemoteIpAddress?.ToString(),
                    UserId = int.Parse(user.FindFirst("Id")?.Value),
                    Timestamp = DateTime.Now
                };
                Db.ActivityLogs.Add(activityedit);
                Db.SaveChanges();
                Notif.Show("Artikel berhasil disimpan!", "success");
                Nav.NavigateTo("/Editor");
                return;
            }

            // title and slug
            if (article.Title == null || article.Title.Length == 0)
            {
                Notif.Show("Judul artikel harus di isi!", "error");
                return;
            }

            article.Slug = article.Title.GenerateSlug();
            if (Db.Articles.Any(x => x.Slug == article.Slug || x.Title == article.Title))
            {
                Notif.Show("Judul Berita Sudah ada, silahkan gunakan judul lain!", "error");
            }

            if (selectedImage != null)
            {
                var fileName = $"{Guid.NewGuid()}{Path.GetExtension(selectedImage.Name)}";
                var folderPath = Path.Combine(Env.WebRootPath, "uploads", "thumbnails");

                if (!Directory.Exists(folderPath))
                    Directory.CreateDirectory(folderPath);

                var filePath = Path.Combine(folderPath, fileName);

                using var stream = selectedImage.OpenReadStream(5 * 1024 * 1024);
                using var fs = new FileStream(filePath, FileMode.Create);
                await stream.CopyToAsync(fs);

                // save path to DB
                article.ThumbnailUrl = $"/uploads/thumbnails/{fileName}";
            }
            else
            {
                Notif.Show("Gambar Utama wajib di ada!", "error");
                return;
            }



            // excerpt
            if (string.IsNullOrWhiteSpace(article.Excerpt))
            {
                article.Excerpt = article.Title != null && article.Title.Length > 100 ? article.Title.Substring(0, 100) + "..." : article.Title;
            }

            // meta
            article.MetaTitle = article.Title;
            article.MetaDescription = article.Excerpt;

            article.AuthorId = int.Parse(user.FindFirst("Id")?.Value);
            article.CreatedAt = DateTime.Now;

            article.UpdatedAt = DateTime.Now;

            if(article.Status == (int)ArticleStatus.Published)
            {
                article.PublishedAt = DateTime.Now;
            }

            // search category and subcategory from database

            var cat = Db.Categories.Find(SelectedCategoryId);
            if(cat == null)
            {
                Notif.Show("Kategori tidak ada!", "error");
                return;
            }
            article.Cat = cat;
            var subcat = Db.SubCategories.Find(SelectedSubCategoryId);
            if (subcat != null)
                article.SubCat = subcat;

            Db.Articles.Add(article);
            Db.SaveChanges();

            // Activity Log
            var activity = new ActivityLogs
                {
                    Action = "create",
                    Details = "Membuat artikel: " + article.Title,
                    IpAddress = HttpContextAccessor.HttpContext?.Connection?.RemoteIpAddress?.ToString(),
                    UserId = int.Parse(user.FindFirst("Id")?.Value),
                    Timestamp = DateTime.Now
                };
            Db.ActivityLogs.Add(activity);
            Db.SaveChanges();

            Notif.Show("Artikel berhasil disimpan!", "success");
            Nav.NavigateTo("/Editor");
        }catch(Exception ex)
        {
            Notif.Show(ex.Message, "error");
            Console.WriteLine(ex.Message);
        }
    }


}